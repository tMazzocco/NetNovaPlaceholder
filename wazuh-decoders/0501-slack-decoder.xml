<!--
  Slack source decoder for the wazuh-slack connector.
  Events arrive on the analysisd queue with location prefix `slack-<source>`
  and the NormalizedEvent JSON payload (top-level fields: @timestamp, slack.*,
  severity, raw). Wazuh's built-in JSON decoder handles field extraction;
  this file just attaches the `slack` decoder name and groups so rules can
  match on `<decoded_as>slack</decoded_as>`.
-->
<decoder name="slack">
  <prematch>^{</prematch>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>

<decoder name="slack-audit">
  <parent>slack</parent>
  <use_own_name>true</use_own_name>
  <program_name_pcre2>^slack-audit$</program_name_pcre2>
</decoder>

<decoder name="slack-events">
  <parent>slack</parent>
  <use_own_name>true</use_own_name>
  <program_name_pcre2>^slack-events$</program_name_pcre2>
</decoder>

<decoder name="slack-access">
  <parent>slack</parent>
  <use_own_name>true</use_own_name>
  <program_name_pcre2>^slack-access$</program_name_pcre2>
</decoder>

<decoder name="slack-inventory">
  <parent>slack</parent>
  <use_own_name>true</use_own_name>
  <program_name_pcre2>^slack-inventory$</program_name_pcre2>
</decoder>
