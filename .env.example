# Copy to .env and fill in. docker compose auto-loads .env.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
# User token (xoxp-) with auditlogs:read — required only for the audit source
# (Enterprise Grid). Leave blank if you are not enabling sources.audit.
SLACK_USER_TOKEN=xoxp-your-user-token
